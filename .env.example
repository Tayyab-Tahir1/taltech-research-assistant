# Copy this file to .env and fill in your values.
# Streamlit Cloud: set these under "Advanced settings → Secrets" (TOML format).
# HuggingFace Spaces: set these as Repository Secrets.

# ── LLM backend switch ───────────────────────────────────────────────────────
# One of: gemini (default), openai, local
# LLM_BACKEND=gemini

# ── Gemini (default backend, free tier) ──────────────────────────────────────
# Required when LLM_BACKEND=gemini
GOOGLE_API_KEY=AIza...

# Optional model overrides (defaults shown)
# GEMINI_FAST_MODEL=gemini-2.5-flash
# GEMINI_DEEP_MODEL=gemini-2.5-pro

# ── OpenAI (escape hatch) ────────────────────────────────────────────────────
# Required when LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Optional: dataset search (Kaggle) ────────────────────────────────────────
# Both must be set together. Leave blank to use Zenodo only.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# ── Optional: GitHub higher rate limit (60/hr → 5000/hr) ─────────────────────
# GITHUB_TOKEN=ghp_...

# ── Optional: local vLLM via SLURM ───────────────────────────────────────────
# Set LLM_BACKEND=local and point at your ngrok URL.
# LOCAL_MODEL_URL=https://xxxx.ngrok-free.app
# LOCAL_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
# LOCAL_MODEL_API_KEY=none

# ── Google OAuth for per-user chat history ───────────────────────────────────
# Configured in .streamlit/secrets.toml (not .env) as a [auth] block:
#   [auth]
#   redirect_uri = "https://<app>.streamlit.app/oauth2callback"
#   cookie_secret = "<32-byte random string>"
#   client_id = "<google oauth client id>"
#   client_secret = "<google oauth secret>"
#   server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
# When [auth] is absent, the app falls back to a single local@localhost user.

# ── Optional: deployment flags ───────────────────────────────────────────────
# Set to "true" on Streamlit Community Cloud deployments (informational only).
# STREAMLIT_CLOUD=true

# ── Optional: logging ────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR. Default: INFO.
# LOG_LEVEL=INFO
